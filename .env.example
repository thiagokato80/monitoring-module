# MonitoringModule — variáveis de ambiente
# Tier: 1=Minimal | 2=Standard (banco) | 3=Full (backup + DR)
MONITORING_TIER=1
MONITORING_APP_ID=minha-app
# Secret gerado pelo cliente via POST /admin/monitoring/generate-secret
# Configurar aqui o valor em texto claro (o hash SHA-256 é derivado automaticamente)
MONITORING_SECRET=
# Hash SHA-256 do secret gerado pelo cliente via POST /admin/monitoring/generate-secret
MONITORING_SECRET_HASH=
MONITORING_HUB_URL=https://freelancerhq.app/api/monitoring/ingest
# IPs do FreelancerHQ autorizados (separados por vírgula)
MONITORING_ALLOWED_IPS=

# Tier 2+ — banco de dados
# DB_PROVIDER=supabase
# DATABASE_URL=postgresql://...

# Operação
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Sistema em manutenção. Retorne em breve.
